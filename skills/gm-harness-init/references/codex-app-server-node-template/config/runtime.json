{
  "model": "gpt-5.4",
  "serviceName": "gm_harness_init_template",
  "reportDir": ".harness/reports",
  "logDir": "harness/logs",
  "generator": {
    "approvalPolicy": "on-request",
    "sandbox": "workspace-write"
  },
  "evaluator": {
    "approvalPolicy": "never",
